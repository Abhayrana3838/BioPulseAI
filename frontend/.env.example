# API Keys for Fleet Logistics Dashboard
# Copy this file to .env and replace with your actual API keys

# Google Maps API Key
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console
# 2. Create a new project or select existing
# 3. Enable "Maps JavaScript API" and "Places API"
# 4. Create credentials -> API Key
# 5. Copy the key below
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# 1. Login to OpenAI platform
# 2. Click "Create new secret key"
# 3. Copy the key below
REACT_APP_OPENAI_API_KEY=your_openai_api_key_here

# Optional: Other API keys for future features
# REACT_APP_MAPBOX_API_KEY=your_mapbox_api_key_here
# REACT_APP_TOMTOM_API_KEY=your_tomtom_api_key_here
